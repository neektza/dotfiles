#!/bin/zsh

ZSH=$HOME/.oh-my-zsh
DOTFILES=$HOME/dotfiles

export PATH=$PATH:$HOME/bin
{{ if eq .chezmoi.os "darwin" -}}
export PATH=$PATH:$HOME/.dotnet/tools
export PATH=$PATH:/Library/TeX/texbin
export PATH=/Applications/Docker.app/Contents/Resources/bin:$PATH
export PATH=/opt/homebrew/opt/dotnet@8/bin:$PATH
{{ end -}}

export EDITOR=nvim
export LC_CTYPE=en_US.UTF-8
export LANG=en_US.UTF-8
{{ if eq .chezmoi.os "darwin" -}}
export SSH_AUTH_SOCK=~/.1password/agent.sock
{{ end -}}
export PGDATABASE=postgres
export LESS='-R --mouse'

unsetopt correct_all

# Some commons
alias vim=nvim
alias act='source ./.venv/bin/activate'

# Search
alias ack='ack -r'
alias grep='egrep -i'

# Fuckups
alias gti='git'

alias ag=rg

alias clrf="perl -pi -e 's/\r/\n/g'"

# Direnv
eval "$(direnv hook zsh)"

# OH MY ZSH begin
{{- if eq .chezmoi.hostname "pwrbook" }}
ZSH_THEME="sonicradish"
{{- else if eq .chezmoi.hostname "hermes-v2" }}
ZSH_THEME="afowler"
{{- else }}
ZSH_THEME="ys"
{{- end }}
{{ if eq .chezmoi.os "darwin" -}}
plugins=(git fzf brew docker npm node)
{{ else -}}
plugins=(git fzf docker npm node)
{{ end -}}
source $ZSH/oh-my-zsh.sh

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

{{ if eq .chezmoi.os "darwin" -}}
# Docker CLI completions
fpath=({{ .chezmoi.homeDir }}/.docker/completions $fpath)
autoload -Uz compinit
compinit

# .NET
export DOTNET_ROOT=/opt/homebrew/opt/dotnet@8/libexec
{{ end -}}

# bun completions
[ -s "{{ .chezmoi.homeDir }}/.bun/_bun" ] && source "{{ .chezmoi.homeDir }}/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Trackframe completions
command -v trackframe &>/dev/null && eval "$(trackframe completion zsh)"

# opt+arrow word navigation (ghostty unbinds alt+arrows, macos-option-as-alt sends \e[1;3C/D)
bindkey "\e[1;3C" forward-word
bindkey "\e[1;3D" backward-word

# Ghostty helpers
[[ -f ~/.config/ghostty/themes.zsh ]] && source ~/.config/ghostty/themes.zsh
[[ -f ~/.config/ghostty/profiles.zsh ]] && source ~/.config/ghostty/profiles.zsh

# Zellij aliases and completions
if command -v zellij &>/dev/null; then
  alias za='zellij attach'
  alias zl='zellij list-sessions'
  alias zk='zellij kill-session'
  alias zka='zellij kill-all-sessions'
  alias zd='zellij delete-session'
  alias zda='zellij delete-all-sessions'
  alias zw='zellij watch'

  # write completions to fpath once (regenerate if zellij binary is newer)
  _zellij_comp_file="${HOME}/.zfunc/_zellij"
  if [[ ! -f "$_zellij_comp_file" || "$(command -v zellij)" -nt "$_zellij_comp_file" ]]; then
    mkdir -p "${HOME}/.zfunc"
    zellij setup --generate-completion zsh >! "$_zellij_comp_file" 2>/dev/null
  fi
  fpath=("${HOME}/.zfunc" $fpath)

  # session name completion for aliases that take a session argument
  _zellij_sessions() {
    local sessions
    sessions=(${(f)"$(zellij list-sessions 2>/dev/null | awk '{print $1}')"})
    _describe 'sessions' sessions
  }
  _zellij_session_cmd() { _arguments '1:session:_zellij_sessions' }
  compdef _zellij_session_cmd za zk zd zw
fi

# per-host config (dotfiles/zshrc.d/<hostname>.zsh)
[[ -f $DOTFILES/zshrc.d/$(hostname).zsh ]] && source $DOTFILES/zshrc.d/$(hostname).zsh
