# Ghostty base config — defaults applied to every window.
# Per-window color schemes via: gop <profile>   (secondary, tertiary, quaternary, personal, dark)
# Manual in-place repaint via:  gth <profile>   (or gth <profile>-dark for the dark palette)

# --- font / appearance ---
font-family = "MesloLGS NF"
font-size = 16
cursor-style = block
cursor-style-blink = false
window-padding-x = 8
window-padding-y = 6
window-padding-balance = true
macos-titlebar-style = transparent
macos-option-as-alt = true

# --- default theme, auto-switches with macOS appearance ---
theme = dark:/Users/neektza/.config/ghostty/themes/it-dark-local.conf,light:/Users/neektza/.config/ghostty/themes/it-light-local.conf

# --- unbind default word-movement so opt+arrows send \e[1;3C/D to remote ---
keybind = alt+left=unbind
keybind = alt+right=unbind

# --- cmd+1..0 → Ctrl+Alt+1..0 → Zellij GoToTab (KKP modifier 7 = ctrl+alt) ---
# ghostty has two default bindings per digit (super+1 and super+digit_1), unbind both
keybind = super+digit_1=unbind
keybind = super+digit_2=unbind
keybind = super+digit_3=unbind
keybind = super+digit_4=unbind
keybind = super+digit_5=unbind
keybind = super+digit_6=unbind
keybind = super+digit_7=unbind
keybind = super+digit_8=unbind
keybind = super+digit_9=unbind
keybind = cmd+1=unbind
keybind = cmd+2=unbind
keybind = cmd+3=unbind
keybind = cmd+4=unbind
keybind = cmd+5=unbind
keybind = cmd+6=unbind
keybind = cmd+7=unbind
keybind = cmd+8=unbind
keybind = cmd+9=unbind
keybind = cmd+0=unbind
keybind = cmd+1=text:\x1b[49;7u
keybind = cmd+2=text:\x1b[50;7u
keybind = cmd+3=text:\x1b[51;7u
keybind = cmd+4=text:\x1b[52;7u
keybind = cmd+5=text:\x1b[53;7u
keybind = cmd+6=text:\x1b[54;7u
keybind = cmd+7=text:\x1b[55;7u
keybind = cmd+8=text:\x1b[56;7u
keybind = cmd+9=text:\x1b[57;7u
keybind = cmd+0=text:\x1b[48;7u

# --- iTerm-style keybinds ---
keybind = cmd+t=new_tab
keybind = cmd+n=new_window
keybind = cmd+w=close_surface
keybind = cmd+shift+w=close_window
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:up
keybind = cmd+alt+down=goto_split:down
keybind = cmd+k=clear_screen
keybind = cmd+f=open_config
keybind = cmd+shift+r=reload_config

# --- quick (drop-down) terminal, iTerm hotkey-window analog ---
keybind = global:cmd+grave_accent=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-screen = main
