[user]
	name = Nikica Jokic
	email = neektza@gmail.com
[credential "https://github.com"]
	username = neektza
[core]
	editor = vim
	pager = bat --paging=always --style=numbers,changes
[color]
	status = auto
	diff = auto
	branch = auto
[alias]
	a = add
	f = fetch
	au = add -u
	aa = add -A
	st = status
	ci = commit
	co = checkout
	cp = cherry-pick
	br = branch
	df = diff
	dfs = diff --staged
	sm = submodule
	lg = log -p
	rs = reset

	head = !git r -1
	h = !git head
	hp = "!. ~/.githelpers && show_git_head"
	r = !GIT_NO_PAGER=1 git l -30
	ra = !git r --all
	l = "!. ~/.githelpers && pretty_git_log"
	la = !git l --all
	b = "!. ~/.githelpers && pretty_git_branch"
	bs = "!. ~/.githelpers && pretty_git_branch_sorted"
	batdiff = !git diff --name-only --diff-filter=d | xargs bat --diff
	batlog = "!f() { git log --patch $@ | bat -l diff; }; f"

[difftool]
	tool = vimdiff
	prompt = false
[mergetool]
	tool = vimdiff
	prompt = false
[merge]
	tool = vimdiff
[push]
	default = simple
[init]
	defaultBranch = master
[pull]
	rebase = false
[delta]
	features = syntax-highlighting
[diff "jupyternotebook"]
	command = git-nbdiffdriver diff
[merge "jupyternotebook"]
	driver = git-nbmergedriver merge %O %A %B %L %P
	name = jupyter notebook merge driver
[difftool "nbdime"]
	cmd = git-nbdifftool diff \"$LOCAL\" \"$REMOTE\" \"$BASE\"
[mergetool "nbdime"]
	cmd = git-nbmergetool merge \"$BASE\" \"$LOCAL\" \"$REMOTE\" \"$MERGED\"
