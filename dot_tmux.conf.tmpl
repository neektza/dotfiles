set -g prefix C-a
set -g mode-keys vi

# enable mouse support
set -g mouse on

# start windows and panes at 1, not 0
set -g base-index 1
set -g pane-base-index 1

# visual preferences
set -g status-style fg=white,bg=default,bright
setw -g window-status-style fg=white,bg=default,dim
setw -g window-status-current-style fg=white,bg=default,bright

# resurrect configuration
set -g @resurrect-strategy-vim 'session'
set -g @resurrect-processes 'ssh psql sqlite3'

# List of plugins
set -g @tpm_plugins '		       \
  tmux-plugins/tpm                 \
  tmux-plugins/tmux-sensible       \
  tmux-plugins/tmux-resurrect      \
  tmux-plugins/tmux-yank           \
  tmux-plugins/tmux-open           \
  tmux-plugins/tmux-sessionist     \
  tmux-plugins/tmux-pain-control   \
  tmux-plugins/tmux-copycat        \
'

# Generated by tmuxline.vim
source '{{ .chezmoi.homeDir }}/.tmuxline.conf'

# Initializes TMUX plugin manager.
# Keep this line at the very bottom of tmux.conf.
run-shell '~/.tmux/plugins/tpm/tpm'
